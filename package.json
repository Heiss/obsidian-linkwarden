{
  "name": "obsidian-linkwarden",
  "version": "0.1.0",
  "description": "The Linkwarden plugin for Obsidian: search/link saved links, archive URLs, show highlights beside notes, and insert highlights as quotes.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "gen:api": "openapi-typescript openapi/linkwarden.yaml -o src/api/schema.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "obsidian",
    "linkwarden",
    "highlights"
  ],
  "author": "Peter Heiss",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.5.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.24.0",
    "obsidian": "^1.7.2",
    "openapi-typescript": "^7.13.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
